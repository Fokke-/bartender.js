{
  "name": "bartender-monorepo",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "type": "module",
  "scripts": {
    "dev:core": "pnpm --filter @fokke-/bartender.js dev",
    "dev:vue": "pnpm --filter @fokke-/vue-bartender.js dev",
    "build": "pnpm --filter @fokke-/bartender.js build && pnpm --filter @fokke-/vue-bartender.js build",
    "lint": "eslint packages/",
    "format": "prettier --write ./",
    "test": "pnpm --filter @fokke-/bartender.js test",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@fokke-/bartender.js": "workspace:*",
    "@fokke-/vue-bartender.js": "workspace:*",
    "@changesets/cli": "2.29.4",
    "@types/node": "25.5.0",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "eslint": "10.1.0",
    "eslint-plugin-vue": "10.8.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "sass-embedded": "1.98.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vite": "8.0.3",
    "vite-plugin-dts": "4.5.4",
    "vitepress": "1.6.4",
    "vue": "3.5.31",
    "vue-tsc": "3.2.6"
  },
  "lint-staged": {
    "*.{js,ts,mts,tsx,vue}": [
      "eslint",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yaml,yml}": [
      "prettier --write"
    ]
  }
}
