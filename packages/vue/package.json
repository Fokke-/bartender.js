      "import": "./dist/vue-bartender.js"
    }
  },
  "peerDependencies": {
    "@fokke-/bartender.js": "^3.2.1",
    "vue": "^3.5"
  },
  "devDependencies": {
    "@fokke-/bartender.js": "workspace:^",
    "@vitejs/plugin-vue": "6.0.5",
    "modern-normalize": "3.0.1",
    "vue-router": "5.0.4",
    "@vitest/browser": "4.1.2",
    "@vitest/browser-playwright": "4.1.2",
    "playwright": "1.58.2",
    "vitest": "4.1.2"
  }
