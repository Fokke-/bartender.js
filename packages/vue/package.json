{
  "name": "@fokke-/vue-bartender.js",
  "version": "1.2.1",
  "description": "Bartender.js plugin for Vue 3",
  "author": "Ville Fokke Saarivaara",
  "license": "MIT",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fokke-/bartender.js",
    "directory": "packages/vue"
  },
  "keywords": [
    "off-canvas",
    "accessibility",
    "a11y",
    "sidebar",
    "navigation",
    "vue"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
